# Green-API credentials (https://green-api.com)
GREEN_API_INSTANCE_ID=your_instance_id_here
GREEN_API_TOKEN=your_token_here

# Anthropic Claude API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Server
PORT=3000

# Test mode — set TEST_MODE=true to restrict the bot to a single phone number.
# Only messages from TEST_PHONE that start with #test will be processed.
# Send #endtest to close the active test session.
TEST_MODE=false
TEST_PHONE=972500000000
